{% schema %}
{
  "name": "Collection Banner",
  "settings": [],
  "presets": [{
    "name": "Collection Banner"
  }]
}
{% endschema %}

<section class="collection-banner" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);">
  <div class="container">
    <h1>{{ collection.title }}</h1>
    <p>{{ collection.description }}</p>
  </div>
</section>

<style>
  .collection-banner {
    padding: 4rem 2rem;
    color: white;
    text-align: center;
  }
  
  .collection-banner h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: white;
  }
  
  .collection-banner p {
    font-size: 1.1rem;
  }
</style>